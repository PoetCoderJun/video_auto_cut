# Direct-prompt LLM provider. Use your own OpenAI-compatible endpoint.
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_ENABLE_THINKING=0

# Optional ASR path for media input. SRT input does not need these.
ASR_BACKEND=dashscope_filetrans
DASHSCOPE_ASR_BASE_URL=https://dashscope-intl.aliyuncs.com
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-filetrans
DASHSCOPE_ASR_API_KEY=
DASHSCOPE_ASR_LANGUAGE=zh
DASHSCOPE_ASR_ENABLE_ITN=0
DASHSCOPE_ASR_ENABLE_WORDS=1

# Optional object storage used by the DashScope file-transcription adapter.
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PREFIX=poetcut-core/asr
OSS_SIGNED_URL_TTL_SECONDS=86400

# Local logging.
LOG_LEVEL=INFO
LOG_FORMAT=text
