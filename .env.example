# --------------------
# Core local web app
# --------------------
TURSO_DATABASE_URL=libsql://<your-db>-<org>.turso.io
TURSO_AUTH_TOKEN=<your-token>
TURSO_LOCAL_REPLICA_PATH=./workdir/web_api_turso_replica.db

WEB_AUTH_ENABLED=1
BETTER_AUTH_SECRET=<strong-random-secret-at-least-32-chars>
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
BETTER_AUTH_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000/api/v1
WEB_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-5NFPXTC63E
# Optional Google Search Console ownership verification meta value.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --------------------
# LLM / direct prompt editing path
# --------------------
LLM_BASE_URL=<openai-compatible-base-url>
LLM_MODEL=kimi-k2.5
LLM_API_KEY=<optional, fallback to DASHSCOPE_API_KEY>
DASHSCOPE_API_KEY=<optional fallback>
LLM_ENABLE_THINKING=0

# --------------------
# ASR + OSS
# --------------------
ASR_BACKEND=dashscope_filetrans
DASHSCOPE_ASR_BASE_URL=https://dashscope-intl.aliyuncs.com
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-filetrans
DASHSCOPE_ASR_API_KEY=<optional, fallback to DASHSCOPE_API_KEY>
DASHSCOPE_ASR_LANGUAGE=zh
DASHSCOPE_ASR_ENABLE_ITN=0
DASHSCOPE_ASR_ENABLE_WORDS=1
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=<your-oss-bucket>
OSS_ACCESS_KEY_ID=<your-ak>
OSS_ACCESS_KEY_SECRET=<your-sk>

# --------------------
# Logging (structured / observability)
# --------------------
# LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_FORMAT=auto         # auto | json | text  (auto: json in prod/Railway, text in dev tty)

# --------------------
# Runtime artifact cleanup / disk guardrails
# --------------------
# WEB_CLEANUP_ENABLED=1
# WEB_CLEANUP_INTERVAL_SECONDS=300
# WEB_CLEANUP_TTL_SECONDS=3600
# WEB_CLEANUP_STALE_JOB_SECONDS=21600
# WEB_CLEANUP_STALE_STATUSES=CREATED,UPLOAD_READY,TEST_RUNNING,FAILED
# WEB_CLEANUP_BATCH_SIZE=10
# WEB_CLEANUP_ON_STARTUP=1

# --------------------
# Optional advanced overrides
# --------------------
WEB_AUTH_BASE_URL=http://127.0.0.1:3000
WEB_AUTH_ISSUER=http://127.0.0.1:3000
WEB_AUTH_AUDIENCE=http://127.0.0.1:3000
WEB_AUTH_JWKS_URL=http://127.0.0.1:3000/api/auth/jwks

DASHSCOPE_ASR_TASK=
DASHSCOPE_ASR_TEXT=
DASHSCOPE_ASR_CHANNEL_IDS=0
ASR_SENTENCE_RULE_WITH_PUNC=1
ASR_WORD_SPLIT_ENABLED=1
ASR_WORD_SPLIT_ON_COMMA=1
ASR_WORD_SPLIT_COMMA_PAUSE_S=0.4
ASR_WORD_SPLIT_MIN_CHARS=12
ASR_WORD_VAD_GAP_S=1.0
ASR_WORD_MAX_SEGMENT_S=8.0
ASR_NO_SPEECH_GAP_S=1.0
ASR_INSERT_NO_SPEECH=1
ASR_INSERT_HEAD_NO_SPEECH=1
OSS_PREFIX=video-auto-cut/asr
OSS_SIGNED_URL_TTL_SECONDS=86400
